# OpenCellID API (free tier: https://opencellid.org/)
OPENCELLID_API_KEY=your_key_here

# Mapbox or other mapping service (https://www.mapbox.com/)
MAPBOX_ACCESS_TOKEN=your_token_here

# Flask configuration
FLASK_SECRET_KEY=generate_a_random_secret_key_here
FLASK_ENV=development
FLASK_DEBUG=True

# Optional: Database
# DATABASE_URL=sqlite:///cell_towers.db
# COSMOS_DB_ENDPOINT=https://your-account.documents.azure.com:443/
# COSMOS_DB_KEY=your_key_here

# App settings
REFRESH_INTERVAL_SECONDS=10
MAX_TOWER_HISTORY=1000
ENABLE_GAMIFICATION=True
