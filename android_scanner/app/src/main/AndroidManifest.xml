<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.cellseeu.scanner">

    <!-- Required permissions for cell tower scanning -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.INTERNET" />
    
    <!-- WiFi scanning permissions -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    
    <!-- Optional: For background scanning -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Minimum SDK: Android 6.0 (Marshmallow) for runtime permissions -->
    <uses-sdk
        android:minSdkVersion="23"
        android:targetSdkVersion="34" />

    <application
        android:allowBackup="true"
        android:icon="@android:drawable/sym_def_app_icon"
        android:label="CellSeeU Scanner"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCompat.Light"
        android:usesCleartextTraffic="true">

        <!-- Main Activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- WiFi 3D Visualization Activity -->
        <activity
            android:name=".WiFi3DActivity"
            android:exported="false"
            android:label="WiFi 3D View"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar">
        </activity>

        <activity
            android:name=".SignalMapActivity"
            android:exported="false"
            android:label="Signal Map"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar">
        </activity>

    </application>
    
    <!-- OpenGL ES 2.0 requirement -->
    <uses-feature android:glEsVersion="0x00020000" android:required="true" />

</manifest>
